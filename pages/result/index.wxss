/* pages/result/index.wxss */
.page {
  min-height: 100vh;
  padding: 200rpx 32rpx 48rpx;
  box-sizing: border-box;
}

.result-header {
  background: var(--bg-card);
  border-radius: 12rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  margin-bottom: 24rpx;
}

.emoji-large {
  font-size: 120rpx;
  display: block;
  margin-bottom: 24rpx;
}

.result-type-badge {
  display: inline-block;
  padding: 8rpx 24rpx;
  background: #f3f4f6;
  color: var(--text-secondary);
  font-size: 24rpx;
  font-weight: 600;
  border-radius: 4rpx;
  margin-bottom: 24rpx;
}

.result-name {
  display: block;
  font-size: 56rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

.result-traits {
  margin-bottom: 24rpx;
}

.traits-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.8;
  display: block;
}

.mbti-tag {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: #eff6ff;
  border-radius: 8rpx;
}

.mbti-label {
  font-size: 24rpx;
  color: #6b7280;
  margin-right: 12rpx;
}

.mbti-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #3b82f6;
}

.result-section {
  background: var(--bg-card);
  border-radius: 12rpx;
  padding: 32rpx;
  margin-bottom: 16rpx;
}

.section-title {
  margin-bottom: 20rpx;
}

.section-title text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.section-content {
  padding: 24rpx;
  background: var(--bg-page);
  border-radius: 8rpx;
}

.desc-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.8;
  text-align: justify;
}

.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-item {
  padding: 12rpx 24rpx;
  background: #f3f4f6;
  color: var(--text-secondary);
  font-size: 26rpx;
  border-radius: 4rpx;
}

.share-quote {
  padding: 32rpx;
  background: #fffbeb;
  border-radius: 8rpx;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.quote-mark {
  font-size: 36rpx;
  color: #f59e0b;
  font-weight: 300;
}

.quote-text {
  font-size: 30rpx;
  color: #92400e;
  font-style: italic;
  line-height: 1.6;
  flex: 1;
}

.actions {
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.action-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 8rpx;
  border: none;
  text-align: center;
}

.action-btn.primary {
  background: var(--primary-color);
  color: #fff;
}

.action-btn.primary:active {
  opacity: 0.8;
}

.action-btn.secondary {
  background: var(--bg-card);
  color: var(--text-primary);
  border: 2rpx solid var(--border-color);
}

.action-btn.secondary:active {
  background: var(--bg-page);
}
